@model FUNewsManagementSystem.Data.Entities.SystemAccount
@{
    ViewData["Title"] = "My Profile";
}
<h1>My Profile</h1>
<form asp-action="Profile" method="post" class="col-md-6">
    <input asp-for="AccountId" type="hidden" />
    <input asp-for="AccountRole" type="hidden" />
    <div class="mb-3"><label asp-for="AccountName" class="form-label"></label><input asp-for="AccountName" class="form-control" /></div>
    <div class="mb-3"><label asp-for="AccountEmail" class="form-label"></label><input asp-for="AccountEmail" class="form-control" /></div>
    <div class="mb-3"><label asp-for="AccountPassword" class="form-label"></label><input asp-for="AccountPassword" class="form-control" /></div>
    <button class="btn btn-primary">Save profile</button>
</form>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
