@model FUNewsManagementSystem.Web.ViewModels.NewsEditViewModel
@using FUNewsManagementSystem.Data.Entities
@{
    ViewData["Title"] = string.IsNullOrWhiteSpace(Model.NewsArticleId) ? "Create News" : "Edit News";
    var tags = (IReadOnlyList<Tag>)ViewBag.Tags;
}
<h1>@ViewData["Title"]</h1>
<form asp-action="Save" method="post" class="col-md-8">
    <div asp-validation-summary="All" class="text-danger"></div>
    <input asp-for="NewsArticleId" type="hidden" />
    <div class="mb-3"><label asp-for="NewsTitle" class="form-label"></label><input asp-for="NewsTitle" class="form-control" /></div>
    <div class="mb-3"><label asp-for="Headline" class="form-label"></label><input asp-for="Headline" class="form-control" /></div>
    <div class="mb-3"><label asp-for="CreatedDate" class="form-label"></label><input asp-for="CreatedDate" type="date" class="form-control" /></div>
    <div class="mb-3"><label asp-for="CategoryId" class="form-label"></label><select asp-for="CategoryId" asp-items="ViewBag.Categories" class="form-select"></select></div>
    <div class="mb-3"><label asp-for="NewsContent" class="form-label"></label><textarea asp-for="NewsContent" class="form-control" rows="5"></textarea></div>
    <div class="mb-3"><label asp-for="NewsSource" class="form-label"></label><input asp-for="NewsSource" class="form-control" /></div>
    <div class="form-check mb-3"><input asp-for="NewsStatus" class="form-check-input" /><label asp-for="NewsStatus" class="form-check-label">Active</label></div>
    <div class="mb-3">
        <label class="form-label">Tags</label>
        @foreach (var tag in tags)
        {
            <div class="form-check"><input class="form-check-input" type="checkbox" name="TagIds" value="@tag.TagId" @(Model.TagIds.Contains(tag.TagId) ? "checked" : "") /><label class="form-check-label">@tag.TagName</label></div>
        }
    </div>
    <button class="btn btn-primary">Save</button> <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
